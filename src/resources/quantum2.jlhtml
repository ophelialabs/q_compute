                </div>
            </div>
            <div style="margin-top: 20px;">
                <label style="display: block; font-size: 0.9em; color: #555; font-weight: 500; margin-bottom: 8px;">Quick Links:</label>
                <select style="width: 100%; padding: 10px; border: 2px solid #e0e6ed; border-radius: 6px; font-size: 0.95em; cursor: pointer; transition: border-color 0.2s;" 
                        onchange="if(this.value) window.open(this.value, '_blank'); this.selectedIndex=0;" 
